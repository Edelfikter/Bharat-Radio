# Bharat Radio — Environment Variables
# Copy this file to .env for local development.
# Set these as environment variables in your Vercel project settings.

# ─── Neon PostgreSQL ────────────────────────────────────────────────────────
# Get your connection string from: https://console.neon.tech
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Pusher ──────────────────────────────────────────────────────────────────
# Create a free app at: https://pusher.com/
# Then copy the credentials from your Pusher app dashboard.
PUSHER_APP_ID=your_pusher_app_id
PUSHER_KEY=your_pusher_key
PUSHER_SECRET=your_pusher_secret
PUSHER_CLUSTER=mt1

# ─── JWT ─────────────────────────────────────────────────────────────────────
# A long random string used to sign authentication tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret-in-production
